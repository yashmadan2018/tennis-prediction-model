# Streamlit Cloud secrets template
# ─────────────────────────────────────────────────────────────────────────────
# DO NOT commit the real secrets.toml — it is gitignored.
#
# On Streamlit Cloud, paste these key/value pairs into:
#   App Settings → Secrets  (TOML format)
#
# Locally, copy this file to .env (without the [section] headers) or set the
# variables directly in your shell / .env file.

# ── Odds API ──────────────────────────────────────────────────────────────────
# Get your key at https://the-odds-api.com
ODDS_API_KEY = "your_odds_api_key_here"

# ── Pushover alerts ───────────────────────────────────────────────────────────
# Sign up at https://pushover.net
# Create an application to get the API token.
PUSHOVER_USER_KEY  = "your_pushover_user_key"
PUSHOVER_API_TOKEN = "your_pushover_api_token"
