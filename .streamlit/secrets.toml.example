# Streamlit Cloud secrets template
# ─────────────────────────────────────────────────────────────────────────────
# DO NOT commit the real secrets.toml — it is gitignored.
#
# On Streamlit Cloud, paste these key/value pairs into:
#   App Settings → Secrets  (TOML format)
#
# Locally, copy this file to .env (without the [section] headers) or set the
# variables directly in your shell / .env file.

# ── Odds API ──────────────────────────────────────────────────────────────────
# Get your key at https://the-odds-api.com
ODDS_API_KEY = "your_odds_api_key_here"

# ── Twilio SMS alerts ─────────────────────────────────────────────────────────
# Sign up at https://www.twilio.com
# Account SID and Auth Token are on the Twilio Console dashboard.
TWILIO_ACCOUNT_SID  = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN   = "your_auth_token_here"

# The Twilio phone number that sends the SMS (must be a Twilio-provisioned number).
# Format: E.164, e.g. "+15005550006"
TWILIO_FROM_NUMBER  = "+1XXXXXXXXXX"

# Your mobile number that receives the alerts.
# Format: E.164, e.g. "+14155550123"
TWILIO_TO_NUMBER    = "+1XXXXXXXXXX"
